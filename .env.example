# Supabase (NEXT_PUBLIC_ prefix makes these available client-side; anon key is safe to expose)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Admin API protection (keep secret — never expose to browser)
ADMIN_API_KEY=your-admin-api-key

# Vercel Cron protection (auto-set on Vercel)
CRON_SECRET=your-cron-secret

# Vercel Blob (production only)
BLOB_READ_WRITE_TOKEN=your-blob-token
NEXT_PUBLIC_BLOB_BASE_URL=https://your-blob-store.public.blob.vercel-storage.com
